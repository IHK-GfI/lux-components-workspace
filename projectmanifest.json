{
  "manifestVersion": "1",
  "project": {
    "name": "LUX-Demo",
    "id": "lux-components-demo",
    "structure": {
      "type": "gen",
      "subprojects": {
        "lux-components-github-mirror": "lux-components-github-mirror"
      }
    },
    "urls": {
      "application": {
        "entw": "https://lux-demo-dev.gfi.ihk.de/",
        "prod": "https://lux-demo.gfi.ihk.de/"
      },
      "documentation": {
        "confluence": "https://github.com/IHK-GfI/lux-components-workspace/wiki"
      }
    },
    "platforms": {
      "bitbucket": {
        "projectKey": "JAST",
        "repoKey": "lux-components-github-mirror"
      },
      "kubernetes": {
        "id": "lux-components-demo",
        "argocd": "devportal",
        "toolchainVersion": "GEN 3",
        "environments": {
          "build": [
            {
              "namespace": "lux-components-demo-build",
              "cluster": "sl-plattform-build-prod"
            }
          ],
          "deployment": {
            "entw": {
              "namespace": "lux-components-demo-entw",
              "cluster": "sl-app-plat-prod"
            },
            "prod": {
              "namespace": "lux-components-demo-prod",
              "cluster": "sl-app-plat-prod"
            }
          }
        },
        "deployments": {
          "backstage": {
            "imagePath": "lux-components-demo/lux-components-demo"
          }
        }
      }
    }
  },
  "owner": {
    "department": "Architektur & Framework",
    "teamname": "Team Frameworks",
    "serviceline": "Devops",
    "members": [
      {
        "forename": "Thomas",
        "surname": "Dickhut",
        "email": "thomas.dickhut@gfi.ihk.de",
        "roles": ["DEV"]
      }
    ]
  }
